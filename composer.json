{
  "name": "moroz1999/zx-image",
  "description": "Zx Spectrum images converter in PHP",
  "keywords": [
    "php",
    "zx spectrum",
    "zx evolution",
    "sam coupe"
  ],
  "homepage": "https://github.com/moroz1999/zx-image",
  "license": "CC0-1.0",
  "type": "package",
  "require": {
    "php": ">=8.5",
    "moroz1999/gif-creator": "*"
  },
  "autoload": {
    "psr-4": {
      "ZxImage\\": "ZxImage/"
    }
  },
  "require-dev": {
    "vimeo/psalm": "^6.16"
  },
  "scripts": {
    "psalm": "vendor/bin/psalm --memory-limit=2G --use-baseline=psalm-baseline.xml --no-cache --force-jit",
    "psalm-baseline": "vendor/bin/psalm --memory-limit=2G --set-baseline=psalm-baseline.xml --no-cache"
  }
}
