{
  "name": "moroz1999/zx-image",
  "description": "Zx Spectrum images converter in PHP",
  "keywords": [
    "php",
    "zx spectrum",
    "zx evolution",
    "sam coupe"
  ],
  "homepage": "https://github.com/moroz1999/zx-image",
  "license": "CC0-1.0",
  "type": "package",
  "require": {
    "php": ">=8.5",
    "moroz1999/gif-creator": "*",
    "ext-gd": "*"
  },
  "autoload": {
    "psr-4": {
      "ZxImage\\": "ZxImage/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZxImage\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "vimeo/psalm": "^6.16",
    "phpunit/phpunit": "^12.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "psalm": "vendor/bin/psalm --memory-limit=2G --no-cache --threads=1",
    "psalm-baseline": "vendor/bin/psalm --memory-limit=2G --set-baseline=psalm-baseline.xml --no-cache"
  }
}
